<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="@dimen/spacing_xs"
    app:cardBackgroundColor="@color/dash_card"
    app:cardCornerRadius="@dimen/radius_md"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/dash_card_stroke">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_md"
        android:paddingVertical="@dimen/spacing_sm"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/iv_app_icon"
            android:layout_width="@dimen/icon_md"
            android:layout_height="@dimen/icon_md"
            android:layout_marginEnd="@dimen/spacing_md"
            android:importantForAccessibility="no" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_app_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textColor="@color/on_primary"
                android:maxLines="1"
                android:ellipsize="end" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progress_usage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                app:trackThickness="5dp"
                app:trackCornerRadius="3dp"
                app:trackStopIndicatorSize="0dp"
                app:indicatorColor="@color/dash_chart_bar"
                app:trackColor="@color/dash_chart_track"
                android:max="100" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_usage_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textStyle="bold"
            android:textColor="@color/dash_value_accent" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="@dimen/spacing_sm"
            android:src="@drawable/ic_chevron_right"
            app:tint="@color/dash_text_secondary"
            android:importantForAccessibility="no" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
