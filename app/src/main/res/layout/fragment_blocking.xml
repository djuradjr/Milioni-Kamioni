<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_dashboard_gradient"
    android:paddingHorizontal="@dimen/spacing_md">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="10dp"
        android:text="@string/blocking_tools_title"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="@color/on_ink" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:layout_marginBottom="@dimen/spacing_sm">

        <LinearLayout
            android:id="@+id/btn_focus_mode"
            style="@style/Widget.App.ToolCard"
            android:layout_marginEnd="@dimen/spacing_xs">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_sm">

                <ImageView
                    style="@style/Widget.App.ToolIcon"
                    android:src="@drawable/ic_tool_focus"
                    app:tint="@color/dash_amber" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/status_focus"
                    style="@style/Widget.App.ToolStatus" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/blocking_focus_mode"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/on_ink" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/blocking_focus_desc"
                android:textSize="10sp"
                android:lineSpacingMultiplier="1.15"
                android:textColor="@color/dash_navy_muted" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_sleep_mode"
            style="@style/Widget.App.ToolCard"
            android:layout_marginStart="@dimen/spacing_xs">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_sm">

                <ImageView
                    style="@style/Widget.App.ToolIcon"
                    android:src="@drawable/ic_tool_moon"
                    app:tint="@color/dash_amber" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/status_sleep"
                    style="@style/Widget.App.ToolStatus" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/blocking_sleep_mode"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/on_ink" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/blocking_sleep_desc"
                android:textSize="10sp"
                android:lineSpacingMultiplier="1.15"
                android:textColor="@color/dash_navy_muted" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:layout_marginBottom="@dimen/spacing_md">

        <LinearLayout
            android:id="@+id/btn_website_blocking"
            style="@style/Widget.App.ToolCard"
            android:layout_marginEnd="@dimen/spacing_xs">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_sm">

                <ImageView
                    style="@style/Widget.App.ToolIcon"
                    android:src="@drawable/ic_tool_globe"
                    app:tint="@color/dash_amber" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/status_websites"
                    style="@style/Widget.App.ToolStatus" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/blocking_websites"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/on_ink" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/blocking_websites_desc"
                android:textSize="10sp"
                android:lineSpacingMultiplier="1.15"
                android:textColor="@color/dash_navy_muted" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_in_app_blocking"
            style="@style/Widget.App.ToolCard"
            android:layout_marginStart="@dimen/spacing_xs">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_sm">

                <ImageView
                    style="@style/Widget.App.ToolIcon"
                    android:src="@drawable/ic_tool_shield"
                    app:tint="@color/dash_amber" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/status_block_apps"
                    style="@style/Widget.App.ToolStatus" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/blocking_block_apps"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/on_ink" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/blocking_block_apps_desc"
                android:textSize="10sp"
                android:lineSpacingMultiplier="1.15"
                android:textColor="@color/dash_navy_muted" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="bottom"
        android:layout_marginBottom="@dimen/spacing_sm">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/blocking_app_rules"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/on_ink" />

        <TextView
            android:id="@+id/tv_rules_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/dash_text_soft" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_block_rules"
            android:layoutAnimation="@anim/layout_animation_slide_up"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="@dimen/spacing_sm" />

        <LinearLayout
            android:id="@+id/empty_state"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="@dimen/spacing_xl"
            android:visibility="gone">

            <ImageView
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:src="@drawable/ic_block"
                app:tint="@color/glass_white_strong"
                android:importantForAccessibility="no"
                android:layout_marginBottom="@dimen/spacing_md" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/blocking_rules_empty"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@color/on_ink"
                android:layout_marginBottom="@dimen/spacing_xs" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/blocking_rules_empty_desc"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/dash_text_soft"
                android:textAlignment="center" />
        </LinearLayout>
    </FrameLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_add_rule"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:layout_marginBottom="12dp"
        android:text="@string/blocking_add_rule"
        android:textStyle="bold"
        android:textColor="@color/dash_navy_card"
        app:backgroundTint="@color/dash_amber"
        app:cornerRadius="@dimen/radius_ink"
        app:rippleColor="@color/dash_navy_ripple"
        app:icon="@drawable/ic_add"
        app:iconTint="@color/dash_navy_card"
        app:iconSize="16dp"
        app:iconGravity="textStart" />

</LinearLayout>
