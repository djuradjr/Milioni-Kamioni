<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:tabMode="fixed"
        app:tabIndicatorColor="?attr/colorPrimary"
        app:tabIndicatorHeight="3dp"
        app:tabSelectedTextColor="?attr/colorPrimary"
        app:tabTextColor="?attr/colorOnSurfaceVariant"
        app:tabRippleColor="?attr/colorPrimaryContainer">
        <com.google.android.material.tabs.TabItem android:text="@string/stats_daily" />
        <com.google.android.material.tabs.TabItem android:text="@string/stats_weekly" />
        <com.google.android.material.tabs.TabItem android:text="@string/stats_monthly" />
    </com.google.android.material.tabs.TabLayout>

    <LinearLayout
        android:id="@+id/content_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/spacing_md"
        android:paddingTop="@dimen/spacing_md">

        <!-- Hero: gradient total screen time + unlocks + trend badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_stats_hero"
            android:padding="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_md">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dashboard_total_screen_time"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="@color/dash_text_secondary"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/tv_total_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceDisplaySmall"
                android:textStyle="bold"
                android:textColor="@color/on_primary" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/spacing_xs">

                <TextView
                    android:id="@+id/tv_total_unlocks"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="@color/dash_text_secondary" />

                <TextView
                    android:id="@+id/tv_trend"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_badge_glass"
                    android:paddingHorizontal="@dimen/spacing_sm"
                    android:paddingVertical="4dp"
                    android:textAppearance="?attr/textAppearanceLabelMedium"
                    android:textStyle="bold"
                    android:textColor="@color/on_primary"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        <!-- Chart card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:cardCornerRadius="@dimen/radius_md"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stats_activity"
                    android:textAppearance="?attr/textAppearanceTitleSmall"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <com.example.stayfree.ui.common.BarChartView
                    android:id="@+id/bar_chart"
                    android:layout_width="match_parent"
                    android:layout_height="160dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/stats_most_used"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:layout_marginBottom="@dimen/spacing_sm" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_apps"
                android:layoutAnimation="@anim/layout_animation_slide_up"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="@dimen/spacing_md" />

            <LinearLayout
                android:id="@+id/empty_state"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="@dimen/spacing_xl"
                android:visibility="gone">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_stats"
                    app:tint="?attr/colorPrimaryContainer"
                    android:importantForAccessibility="no"
                    android:layout_marginBottom="@dimen/spacing_md" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stats_empty"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:layout_marginBottom="@dimen/spacing_xs" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/stats_empty_desc"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textAlignment="center" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
