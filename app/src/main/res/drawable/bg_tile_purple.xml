<?xml version="1.0" encoding="utf-8"?>
<!-- Aubergine gradient tile with a rounded ripple (Focus mode card). -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/glass_white_strong">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/radius_lg" />
            <gradient
                android:angle="315"
                android:startColor="#3E2A56"
                android:endColor="#5C4177" />
        </shape>
    </item>
</ripple>
