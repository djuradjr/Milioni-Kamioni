    <!-- Accessibility Service -->
    <string name="accessibility_service_description">Block Brainrot koristi uslugu pristupačnosti da prepozna koja je aplikacija ili sajt trenutno otvoren i primeni tvoja pravila blokiranja.</string>

    <!-- Onboarding -->
    <string name="onboarding_usage_title">Pristup korišćenju</string>
    <string name="onboarding_usage_desc">Block Brainrot treba dozvolu da vidi statistiku korišćenja aplikacija. Tako ti pokazujemo tačno koliko vremena provodiš u svakoj aplikaciji.</string>
    <string name="onboarding_accessibility_title">Usluga pristupačnosti</string>
    <string name="onboarding_accessibility_desc">Uključi Block Brainrot u podešavanjima pristupačnosti da bi prepoznao aktivnu aplikaciju i primenio pravila blokiranja.</string>

    <!-- Prominent disclosure (Play policy) -->
    <string name="disclosure_title">Dozvola za pristupačnost</string>
    <string name="disclosure_message">Ova aplikacija koristi Androidovu uslugu pristupačnosti da očita koja je aplikacija trenutno na ekranu, i — samo kada blokiraš određene sajtove — adresnu traku pregledača.\n\nZašto: to je jedini način da se ekran blokade prikaže čim otvoriš blokiranu aplikaciju ili sajt.\n\nGde idu podaci: nigde. Sve se obrađuje i čuva samo na ovom uređaju. Aplikacija nema pristup internetu i nikada ne prikuplja, ne deli niti prodaje ove podatke.</string>
    <string name="disclosure_accept">Prihvati i nastavi</string>
    <string name="disclosure_decline">Ne sada</string>
    <string name="onboarding_overlay_title">Prikaz preko drugih aplikacija</string>
    <string name="onboarding_overlay_desc">Block Brainrot mora da crta preko drugih aplikacija da bi prikazao ekran blokade kad pokušaš da otvoriš blokiranu aplikaciju.</string>
    <string name="onboarding_notifications_title">Obaveštenja</string>
    <string name="onboarding_notifications_desc">Dozvoli obaveštenja da te Block Brainrot upozori kada se približavaš dnevnim limitima.</string>
    <string name="onboarding_battery_title">Optimizacija baterije</string>
    <string name="onboarding_battery_desc">Izuzmi Block Brainrot iz optimizacije baterije da bi pratio vreme i kad je ekran ugašen.</string>

