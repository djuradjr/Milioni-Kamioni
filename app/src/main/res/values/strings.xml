    <string name="onboarding_usage_title">Usage Access</string>
    <string name="onboarding_usage_desc">StayFree needs permission to view your app usage statistics. This lets us show you exactly how much time you spend in each app.</string>
    <string name="onboarding_accessibility_title">Accessibility Service</string>
    <string name="onboarding_accessibility_desc">Enable StayFree in Accessibility Settings to allow it to detect your active app and enforce blocking rules.</string>
    <string name="onboarding_overlay_title">Display Over Other Apps</string>
