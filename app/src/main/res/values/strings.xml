    <!-- Accessibility Service -->
    <!-- Untranslated: dumpsys tooling and the Play a11y declaration reference this exact label -->
    <string name="accessibility_service_label" translatable="false">Block Brainrot Screen Monitor</string>
    <string name="accessibility_service_description">Block Brainrot uses the Accessibility Service to detect which app or website is currently open so it can enforce your blocking rules.</string>

    <!-- Onboarding -->
    <string name="onboarding_usage_title">Usage Access</string>
    <string name="onboarding_usage_desc">Block Brainrot needs permission to view your app usage statistics. This lets us show you exactly how much time you spend in each app.</string>
    <string name="onboarding_accessibility_title">Accessibility Service</string>
    <string name="onboarding_accessibility_desc">Enable Block Brainrot in Accessibility Settings to allow it to detect your active app and enforce blocking rules.</string>

    <!-- Prominent disclosure (Play policy) -->
    <string name="disclosure_title">Accessibility access</string>
    <string name="disclosure_message">This app uses Android\'s Accessibility Service to read which app is currently on screen, and — only when you block specific websites — the browser address bar.\n\nWhy: this is the only way to show the block screen the moment you open a blocked app or site.\n\nWhere the data goes: nowhere. Everything is processed and stored only on this device. The app has no internet access and never collects, shares, or sells this data.</string>
    <string name="disclosure_accept">Accept and continue</string>
    <string name="disclosure_decline">Not now</string>
    <string name="onboarding_overlay_title">Display Over Other Apps</string>
    <string name="onboarding_overlay_desc">Block Brainrot needs to draw over other apps to show the block screen when you try to open a blocked app.</string>
    <string name="onboarding_notifications_title">Notifications</string>
    <string name="onboarding_notifications_desc">Allow notifications so Block Brainrot can alert you when you are approaching your daily limits.</string>
    <string name="onboarding_battery_title">Battery Optimization</string>
    <string name="onboarding_battery_desc">Exclude Block Brainrot from battery optimization so it keeps tracking even when your screen is off.</string>

